# 로컬 마운트 경로 (Drive 데스크탑 동기화 경로)
# macOS: ~/Library/CloudStorage/GoogleDrive-<이메일>/Shared drives/<공유드라이브명>
# WSL:   /mnt/g/Shared drives/<공유드라이브명>
# Windows(git-bash): /g/Shared drives/<공유드라이브명>
# Linux: ~/GoogleDrive/<공유드라이브명>
GDRIVE_RAW_LOCAL_PATH=

# (선택) Slack Incoming Webhook — push 성공 시 팀에 갱신 알림
# Slack > Apps > Incoming Webhooks 에서 채널용 URL 발급 후 붙여넣기.
# 비워두면 알림은 조용히 생략된다.
SLACK_WEBHOOK_URL=
